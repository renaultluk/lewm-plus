# SuperPOD environment configuration.
# Copy this file to superpod.env and fill in your values, then run:
#   bash superpod/configure_superpod.sh
#
# All SuperPOD helper scripts source superpod.env to load these variables.

# SLURM account and partition (find with: sacctmgr show user $USER withassoc)
SUPERPOD_ACCOUNT=cse
SUPERPOD_PARTITION_GPU=normal
SUPERPOD_PARTITION_CPU=cpu

# Project group name used for /project and /scratch paths
SUPERPOD_GROUP=cse

# Your HKUST username (no @ust.hk)
SUPERPOD_USER=your_username

# Project directory on SuperPOD
PROJECT_DIR=/project/${SUPERPOD_GROUP}/lewm-plus

# Container image path on SuperPOD
CONTAINER_PATH=$HOME/containers/lewm.sqsh

# Training resource defaults
TRAIN_NODES=1
TRAIN_NTASKS=1
TRAIN_GPUS_PER_NODE=1

# Number of CPU cores per job
CPUS_PER_TASK=28
CPUS_PER_TASK_CPU=8

# Default walltime for training jobs
TRAIN_TIME=12:00:00

# Runtime defaults
STABLEWM_HOME=${PROJECT_DIR}/.stable-wm
SCRATCH_DATA=/scratch/${SUPERPOD_GROUP}/datasets
